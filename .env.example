# Copy to .env and adjust. All values have safe defaults for local development;
# the secrets below MUST be overridden before any real deployment.

# --- HTTP ---
PORT=8080
APP_ENV=development          # development | production
LOG_LEVEL=info               # debug | info | warn | error

# --- Ethereum ---
# Default is a public Sepolia node (no signup). For production throughput use a
# dedicated provider, e.g. https://sepolia.infura.io/v3/<KEY> or Alchemy.
ETH_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
CHAIN_ID=11155111            # 11155111 = Sepolia testnet

# --- Key custody (CHANGE THESE) ---
# Passphrase used to encrypt private keys at rest (Web3 Secret Storage / scrypt).
KEYSTORE_DIR=./data/keystore
KEYSTORE_PASSPHRASE=dev-insecure-passphrase-change-me

# --- Auth (CHANGE THESE) ---
JWT_SECRET=dev-insecure-jwt-secret-change-me
JWT_ISSUER=web3-wallet-api
JWT_EXPIRY=1h
OAUTH_CLIENT_ID=demo-client
OAUTH_CLIENT_SECRET=dev-insecure-client-secret-change-me
